root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.rs]
indent_size = 4
indent_style = space

[*.md]
trim_trailing_whitespace = false

[*.json]
indent_size = 2

[*.yaml]
indent_size = 2

[Makefile]
indent_style = tab

[Cargo.toml]
indent_size = 2

[.gitignore]
indent_size = 2